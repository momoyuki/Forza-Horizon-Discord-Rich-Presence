{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "forzarichpresence",
  "version": "1.1.3",
  "identifier": "com.forzarp.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Forza Rich Presence Settings",
        "width": 530,
        "height": 365,
        "resizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}